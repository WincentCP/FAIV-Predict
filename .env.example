# FAIV Predict local Docker environment template
# Copy to repository-root .env. Never commit the populated file.

# Supabase browser configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Privileged ML service configuration
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres
SUPABASE_KEY=your-secret-or-service-role-key
FRONTEND_URL=http://localhost:3000

# Shared only by the Next.js BFF and ML service. Configure the same value in
# the n8n Header Auth credential; n8n does not receive it as an environment variable.
INTERNAL_API_TOKEN=generate-a-long-random-string

# Optional Gemini helpers
LLM_API_KEY=your-gemini-api-key

# Explicit Instagram Business bindings. Every brand_id must already exist and
# belong to the intended user. Tokens remain server-side.
IG_BRANDS_JSON=[{"brand_id":"00000000-0000-0000-0000-000000000000","instagram_id":"1784...","access_token":"EAAz..."}]
# Maximum historical media retrieved per connected account in one sync.
# The service paginates safely and rejects values outside 1-1000.
IG_SYNC_POST_LIMIT=500

# Stable n8n credential-encryption key. Back it up in a password manager and
# never change it after credentials have been created.
N8N_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/
# Local HTTP requires false. A future HTTPS deployment must set this to true.
N8N_SECURE_COOKIE=false

# SMTP credentials and notification addresses are configured in the n8n UI,
# not in this file or workflow JSON. See n8n/README.md.
