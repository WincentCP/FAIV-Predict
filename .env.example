# ──────────────────────────────────────────────────────────────
#  FAIV Predict — Environment Variables Template
# ──────────────────────────────────────────────────────────────

# === FRONTEND (Next.js) ===
# Place these in frontend/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
NEXT_PUBLIC_ML_SERVICE_URL=http://localhost:8000

# Server-side only (BFF -> ML service)
FASTAPI_URL=http://127.0.0.1:8000
# Optional: Google Gemini API key for AI classify/suggest features.
LLM_API_KEY=your-gemini-api-key
# Optional: override the Gemini model (defaults to gemini-2.5-flash).
LLM_MODEL=gemini-2.5-flash
# Shared secret used to authenticate the BFF -> ML service calls.
# MUST match INTERNAL_API_TOKEN in the ML service. Required in production.
INTERNAL_API_TOKEN=generate-a-long-random-string

# === ML SERVICE (FastAPI) ===
# Place these in ml-service/.env
# DATABASE_URL MUST be a Postgres connection string (NOT the https project URL).
# Supabase: Project Settings > Database > Connection string (URI).
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres
PORT=8000
SUPABASE_URL=https://your-project-id.supabase.co
# service_role key (Project Settings > API) — needed for model Storage upload/download.
SUPABASE_KEY=your-service-role-key
LLM_API_KEY=your-gemini-api-key
# Must match the frontend's INTERNAL_API_TOKEN.
INTERNAL_API_TOKEN=generate-a-long-random-string
# Comma-separated list of allowed CORS origins (production frontend URLs).
FRONTEND_URL=https://your-frontend-domain.com
