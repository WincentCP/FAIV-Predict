# ──────────────────────────────────────────────────────────────
# FAIV Predict — Environment Variables Template
# ──────────────────────────────────────────────────────────────

# === FRONTEND (Next.js) ===
# Place these in frontend/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-side only (BFF -> ML service)
FASTAPI_URL=http://127.0.0.1:8000
# Optional Google Gemini helpers.
LLM_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-2.5-flash
# Shared secret used to authenticate BFF -> ML service calls.
INTERNAL_API_TOKEN=generate-a-long-random-string

# === ML SERVICE (FastAPI) ===
# Place these in ml-service/.env
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres
PORT=8000
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key
INTERNAL_API_TOKEN=generate-a-long-random-string
FRONTEND_URL=https://your-frontend-domain.com

# Bind each Instagram credential set to an existing brands.id UUID. Tokens
# remain server-side; /sync/now never creates or claims brand records.
IG_BRANDS_JSON=[{"brand_id":"00000000-0000-0000-0000-000000000000","instagram_id":"1784...","access_token":"EAAz..."}]

# n8n operator notifications (set in the n8n environment, not the app).
FAIV_ML_URL=http://127.0.0.1:8000
# Generate once and retain in the deployment secret manager. Changing it makes
# existing n8n credentials unreadable.
N8N_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
NOTIFICATION_FROM_EMAIL=alerts@your-domain.com
NOTIFICATION_TO_EMAIL=operator@your-domain.com
