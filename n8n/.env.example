# n8n stores encrypted credentials in its persistent data directory. Set one
# stable random value before the first production start; never commit the value.
N8N_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Must match the frontend and ML service value.
INTERNAL_API_TOKEN=replace-with-the-shared-internal-token

# Operator notifications. The Email Send nodes still require one SMTP
# credential to be selected after the workflow is imported.
NOTIFICATION_FROM_EMAIL=faiv-automation@example.com
NOTIFICATION_TO_EMAIL=operator@example.com

# Local defaults. Override all three behind the production HTTPS reverse proxy.
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false
